{
  "version": 2,
  "builds": [
    {
      "src": "api/weather.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/prices.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/grants.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/weather",
      "dest": "/api/weather.py"
    },
    {
      "src": "/api/prices",
      "dest": "/api/prices.py"
    },
    {
      "src": "/api/grants",
      "dest": "/api/grants.py"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}